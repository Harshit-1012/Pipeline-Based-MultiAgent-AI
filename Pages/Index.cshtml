@page
@model IndexModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pipeline-Based AI Agent</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --bg: #0A0B0D;
                --surface: #111317;
                --surface2: #181B20;
                --border: rgba(255,255,255,0.07);
                --border-hover: rgba(255,255,255,0.14);
                --text: #E8EAF0;
                --muted: #5A6070;
                --accent: #00E5A0;
                --accent-dim: rgba(0,229,160,0.12);
                --accent-dim2: rgba(0,229,160,0.06);
                --blue: #4D9EFF;
                --blue-dim: rgba(77,158,255,0.1);
                --amber: #FFB340;
                --amber-dim: rgba(255,179,64,0.1);
                --red: #FF5F57;
                --purple: #B07EFF;
                --mono: 'JetBrains Mono', monospace;
                --sans: 'Syne', sans-serif;
            }

            body {
                background: var(--bg);
                color: var(--text);
                font-family: var(--sans);
                min-height: 100vh;
                padding: 0;
                overflow-x: hidden;
            }

                /* ── Grid bg ── */
                body::before {
                    content: '';
                    position: fixed;
                    inset: 0;
                    background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
                    background-size: 40px 40px;
                    pointer-events: none;
                    z-index: 0;
                }

            .shell {
                position: relative;
                z-index: 1;
                max-width: 1280px;
                margin: 0 auto;
                padding: 2.5rem 2rem 4rem;
            }

            /* ── Header ── */
            .header {
                display: flex;
                align-items: center;
                gap: 1.25rem;
                margin-bottom: 2.5rem;
            }

            .header-icon {
                width: 44px;
                height: 44px;
                border-radius: 10px;
                background: var(--accent-dim);
                border: 1px solid rgba(0,229,160,0.25);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                flex-shrink: 0;
            }

            .header-meta {
                flex: 1;
            }

            .header-title {
                font-size: 20px;
                font-weight: 700;
                letter-spacing: -0.3px;
                color: var(--text);
                line-height: 1;
                margin-bottom: 3px;
            }

            .header-sub {
                font-size: 12px;
                color: var(--muted);
                font-family: var(--mono);
                letter-spacing: 0.02em;
            }

            .status-dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: var(--muted);
                box-shadow: 0 0 0 3px rgba(90,96,112,0.2);
                transition: background 0.3s, box-shadow 0.3s;
            }

                .status-dot.running {
                    background: var(--accent);
                    box-shadow: 0 0 0 3px rgba(0,229,160,0.2);
                    animation: pulse 1.4s ease-in-out infinite;
                }

            @@keyframes pulse {
                0%, 100% {
                    box-shadow: 0 0 0 3px rgba(0,229,160,0.2);
                }

                50% {
                    box-shadow: 0 0 0 6px rgba(0,229,160,0.07);
                }
            }

            /* ── Input bar ── */
            .input-bar {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 14px;
                padding: 6px 6px 6px 1.25rem;
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 1.75rem;
                transition: border-color 0.2s;
            }

                .input-bar:focus-within {
                    border-color: rgba(0,229,160,0.4);
                    box-shadow: 0 0 0 3px rgba(0,229,160,0.06);
                }

            .input-prefix {
                font-family: var(--mono);
                font-size: 13px;
                color: var(--accent);
                flex-shrink: 0;
                user-select: none;
            }

            .idea-input {
                flex: 1;
                background: transparent;
                border: none;
                outline: none;
                font-family: var(--mono);
                font-size: 14px;
                color: var(--text);
                caret-color: var(--accent);
            }

                .idea-input::placeholder {
                    color: var(--muted);
                }

            .run-btn {
                background: var(--accent);
                color: #0A0B0D;
                border: none;
                border-radius: 9px;
                padding: 10px 22px;
                font-family: var(--sans);
                font-size: 13px;
                font-weight: 600;
                cursor: pointer;
                display: flex;
                align-items: center;
                gap: 8px;
                white-space: nowrap;
                transition: opacity 0.15s, transform 0.1s;
                letter-spacing: 0.01em;
            }

                .run-btn:hover {
                    opacity: 0.88;
                }

                .run-btn:active {
                    transform: scale(0.97);
                }

                .run-btn:disabled {
                    opacity: 0.4;
                    cursor: not-allowed;
                }

                .run-btn svg {
                    width: 14px;
                    height: 14px;
                }

            /* ── Main grid ── */
            .main-grid {
                display: grid;
                grid-template-columns: 420px 1fr;
                gap: 1.25rem;
                align-items: start;
            }

            /* ── Panel shared ── */
            .panel {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 14px;
                overflow: hidden;
            }

            .panel-header {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 14px 16px;
                border-bottom: 1px solid var(--border);
                background: var(--surface2);
            }

            .panel-header-label {
                font-size: 11px;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--muted);
                flex: 1;
            }

            .panel-badge {
                font-family: var(--mono);
                font-size: 11px;
                padding: 2px 8px;
                border-radius: 5px;
                font-weight: 500;
            }

            /* ── Log panel ── */
            .log-panel {
                height: 520px;
                display: flex;
                flex-direction: column;
            }

            .log-body {
                flex: 1;
                overflow-y: auto;
                padding: 12px 0;
                font-family: var(--mono);
                font-size: 12.5px;
                line-height: 1.7;
                scrollbar-width: thin;
                scrollbar-color: var(--border) transparent;
            }

                .log-body::-webkit-scrollbar {
                    width: 4px;
                }

                .log-body::-webkit-scrollbar-thumb {
                    background: var(--border-hover);
                    border-radius: 4px;
                }

            .log-entry {
                display: flex;
                gap: 10px;
                padding: 3px 16px;
                border-left: 2px solid transparent;
                transition: background 0.1s;
            }

                .log-entry:hover {
                    background: rgba(255,255,255,0.02);
                }

                .log-entry.new {
                    animation: fadeSlide 0.25s ease;
                }

            @@keyframes fadeSlide {
                from {
                    opacity: 0;
                    transform: translateX(-4px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            .log-ts {
                color: var(--muted);
                flex-shrink: 0;
                font-size: 11px;
                margin-top: 1px;
            }

            .log-msg {
                color: #C8D0E0;
            }

            .log-entry.agent {
                border-left-color: var(--accent);
            }

                .log-entry.agent .log-msg {
                    color: var(--accent);
                }

            .log-entry.info {
                border-left-color: var(--blue);
            }

                .log-entry.info .log-msg {
                    color: var(--blue);
                }

            .log-entry.warn {
                border-left-color: var(--amber);
            }

                .log-entry.warn .log-msg {
                    color: var(--amber);
                }

            .log-entry.err {
                border-left-color: var(--red);
            }

                .log-entry.err .log-msg {
                    color: var(--red);
                }

            .log-empty {
                padding: 40px 16px;
                text-align: center;
                color: var(--muted);
                font-family: var(--mono);
                font-size: 12px;
            }

            /* ── Output panel ── */
            .out-panel {
                height: 520px;
                display: flex;
                flex-direction: column;
            }

            .out-tabs {
                display: flex;
                gap: 2px;
                padding: 8px 12px;
                border-bottom: 1px solid var(--border);
                background: var(--surface2);
            }

            .out-tab {
                font-family: var(--mono);
                font-size: 11px;
                padding: 4px 12px;
                border-radius: 5px;
                cursor: pointer;
                color: var(--muted);
                border: 1px solid transparent;
                background: transparent;
                transition: all 0.15s;
                white-space: nowrap;
            }

                .out-tab:hover {
                    color: var(--text);
                    background: rgba(255,255,255,0.04);
                }

                .out-tab.active {
                    color: var(--text);
                    background: var(--surface);
                    border-color: var(--border);
                }

            .out-body {
                flex: 1;
                overflow-y: auto;
                padding: 20px;
                scrollbar-width: thin;
                scrollbar-color: var(--border) transparent;
            }

                .out-body::-webkit-scrollbar {
                    width: 4px;
                }

                .out-body::-webkit-scrollbar-thumb {
                    background: var(--border-hover);
                    border-radius: 4px;
                }

            .out-section {
                display: none;
            }

                .out-section.active {
                    display: block;
                }

            .out-section-title {
                font-size: 10px;
                font-weight: 600;
                letter-spacing: 0.1em;
                text-transform: uppercase;
                color: var(--muted);
                margin-bottom: 10px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

                .out-section-title::after {
                    content: '';
                    flex: 1;
                    height: 1px;
                    background: var(--border);
                }

            .out-content {
                font-family: var(--mono);
                font-size: 12.5px;
                line-height: 1.8;
                color: #C8D0E0;
                white-space: pre-wrap;
                word-break: break-word;
            }

            .out-empty {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                height: 100%;
                gap: 12px;
                color: var(--muted);
                font-family: var(--mono);
                font-size: 12px;
                text-align: center;
            }

                .out-empty svg {
                    opacity: 0.2;
                }

            /* ── Agents row ── */
            .agents-row {
                display: grid;
                grid-template-columns: repeat(4, 1fr);
                gap: 10px;
                margin-bottom: 1.25rem;
            }

            .agent-card {
                background: var(--surface);
                border: 1px solid var(--border);
                border-radius: 12px;
                padding: 14px 16px;
                display: flex;
                align-items: center;
                gap: 12px;
                transition: border-color 0.25s;
            }

                .agent-card.active-agent {
                    border-color: rgba(0,229,160,0.3);
                }

                .agent-card.done-agent {
                    border-color: rgba(0,229,160,0.15);
                }

            .agent-icon {
                width: 34px;
                height: 34px;
                border-radius: 8px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 16px;
                flex-shrink: 0;
            }

            .agent-name {
                font-size: 12px;
                font-weight: 600;
                color: var(--text);
                line-height: 1;
                margin-bottom: 3px;
            }

            .agent-status {
                font-family: var(--mono);
                font-size: 10px;
                color: var(--muted);
            }

                .agent-status.running {
                    color: var(--accent);
                }

                .agent-status.done {
                    color: var(--blue);
                }

            /* ── Copy btn ── */
            .copy-btn {
                background: transparent;
                border: 1px solid var(--border);
                border-radius: 6px;
                padding: 4px 10px;
                font-family: var(--mono);
                font-size: 11px;
                color: var(--muted);
                cursor: pointer;
                transition: all 0.15s;
            }

                .copy-btn:hover {
                    border-color: var(--border-hover);
                    color: var(--text);
                }

            @@media (max-width: 900px) {
                .main-grid {
                    grid-template-columns: 1fr;
                }

                .agents-row {
                    grid-template-columns: repeat(2, 1fr);
                }
            }
    </style>
</head>
<body>

    <div class="shell">

        <!-- Header -->
        <div class="header">
            <div class="header-icon">🤖</div>
            <div class="header-meta">
                <div class="header-title">Pipeline-Based AI Agent</div>@* 
                <div class="header-sub">dotnet · signalr · ai-pipeline</div> *@
            </div>
            <div class="status-dot" id="statusDot" title="Idle"></div>
        </div>

        <!-- Input bar -->
        <form method="post" id="workflowForm">
            <div class="input-bar">
                <span class="input-prefix">$&gt;</span>
                <input class="idea-input"
                       type="text"
                       name="Idea"
                       id="ideaInput"
                       placeholder="Describe your idea and let the agents take over..."
                       autocomplete="off"
                       spellcheck="false" />
                <button class="run-btn" type="submit" id="runBtn">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="5,2 14,8 5,14" fill="currentColor" stroke="none" />
                    </svg>
                    Run workflow
                </button>
            </div>
        </form>

        <!-- Agent cards -->
       @*  <div class="agents-row">
            <div class="agent-card" id="agent-req" data-agent="requirements">
                <div class="agent-icon" style="background:var(--accent-dim2);">📋</div>
                <div>
                    <div class="agent-name">Requirements</div>
                    <div class="agent-status" id="st-req">idle</div>
                </div>
            </div>
            <div class="agent-card" id="agent-arch" data-agent="architecture">
                <div class="agent-icon" style="background:var(--blue-dim);">🏗️</div>
                <div>
                    <div class="agent-name">Architecture</div>
                    <div class="agent-status" id="st-arch">idle</div>
                </div>
            </div>
            <div class="agent-card" id="agent-code" data-agent="code">
                <div class="agent-icon" style="background:rgba(176,126,255,0.1);">⚙️</div>
                <div>
                    <div class="agent-name">Code Gen</div>
                    <div class="agent-status" id="st-code">idle</div>
                </div>
            </div>
            <div class="agent-card" id="agent-rev" data-agent="review">
                <div class="agent-icon" style="background:var(--amber-dim);">🔍</div>
                <div>
                    <div class="agent-name">Review</div>
                    <div class="agent-status" id="st-rev">idle</div>
                </div>
            </div>
        </div> *@

        <!-- Panels -->
        <div class="main-grid">

            <!-- Log panel -->
            <div class="panel log-panel">
                <div class="panel-header">
                    <div class="panel-header-label">Agent thinking</div>
                    <span class="panel-badge" id="logCount" style="background:var(--accent-dim);color:var(--accent);">0 events</span>
                    <button class="copy-btn" onclick="clearLogs()">Clear</button>
                </div>
                <div class="log-body" id="logs">
                    <div class="log-empty" id="logEmpty">Waiting for workflow to start…</div>
                </div>
            </div>

            <!-- Output panel -->
            <div class="panel out-panel">
                <div class="panel-header">
                    <div class="panel-header-label">Output</div>
                    <button class="copy-btn" onclick="copyAll()">Copy all</button>
                </div>
                <div class="out-tabs">
                    <button class="out-tab active" onclick="switchTab('all', this)">All</button>
                    <button class="out-tab" onclick="switchTab('requirements', this)">Requirements</button>
                    <button class="out-tab" onclick="switchTab('architecture', this)">Architecture</button>
                    <button class="out-tab" onclick="switchTab('code', this)">Code</button>
                    <button class="out-tab" onclick="switchTab('review', this)">Review</button>
                </div>
                <div class="out-body">

                    <div class="out-section active" id="sec-all">
                        @if (!string.IsNullOrEmpty(Model.FormattedOutput))
                        {
                            <div class="out-content">@Model.FormattedOutput</div>
                        }
                        else
                        {
                            <div class="out-empty" id="outEmpty">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3" /><path d="M9 9h6M9 13h4" /></svg>
                                <span>Run a workflow to see output here</span>
                            </div>
                        }
                    </div>

                    <div class="out-section" id="sec-requirements">
                        <div class="out-section-title">Requirements</div>
                        <pre class="out-content" id="out-requirements">@Model.Requirements</pre>
                    </div>

                    <div class="out-section" id="sec-architecture">
                        <div class="out-section-title">Architecture</div>
                        <pre class="out-content" id="out-architecture">@Model.Architecture</pre>
                    </div>

                    <div class="out-section" id="sec-code">
                        <div class="out-section-title">Generated code</div>
                        <pre class="out-content" id="out-code">@Model.Code</pre>
                    </div>

                    <div class="out-section" id="sec-review">
                        <div class="out-section-title">Review</div>
                        <pre class="out-content" id="out-review">@Model.Review</pre>
                    </div>

                </div>
            </div>
        </div>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        let logCount = 0;
        const logsEl = document.getElementById('logs');
        const logCountEl = document.getElementById('logCount');
        const logEmpty = document.getElementById('logEmpty');
        const statusDot = document.getElementById('statusDot');
        const runBtn = document.getElementById('runBtn');

        const agentKeywords = {
        requirements: ['requirement', 'analyzing', 'gathering', 'spec'],
        architecture: ['architect', 'design', 'structur', 'pattern'],
        code: ['generat', 'coding', 'implement', 'writing code'],
        review: ['review', 'check', 'validat', 'audit']
        };

        const agentIds = { requirements: 'req', architecture: 'arch', code: 'code', review: 'rev' };
        let activeAgent = null;

        function classifyLog(msg) {
        const lower = msg.toLowerCase();
        for (const [agent, kws] of Object.entries(agentKeywords)) {
        if (kws.some(k => lower.includes(k))) return { type: 'agent', agent };
        }
        if (lower.includes('error') || lower.includes('fail')) return { type: 'err' };
        if (lower.includes('warn')) return { type: 'warn' };
        if (lower.includes('start') || lower.includes('connect') || lower.includes('complet')) return { type: 'info' };
        return { type: 'default' };
        }

        function setAgentState(agentKey, state) {
        if (!agentKey) return;
        const shortId = agentIds[agentKey];
        if (!shortId) return;
        const card = document.getElementById('agent-' + shortId);
        const st = document.getElementById('st-' + shortId);
        if (!card || !st) return;
        card.classList.remove('active-agent', 'done-agent');
        st.classList.remove('running', 'done');
        if (state === 'running') {
        card.classList.add('active-agent');
        st.classList.add('running');
        st.textContent = 'running…';
        } else if (state === 'done') {
        card.classList.add('done-agent');
        st.classList.add('done');
        st.textContent = 'done';
        } else {
        st.textContent = 'idle';
        }
        }

        function now() {
        const d = new Date();
        return d.toTimeString().slice(0, 8);
        }

        function addLog(message, type, agent) {
        if (logEmpty) logEmpty.style.display = 'none';
        logCount++;
        logCountEl.textContent = logCount + ' event' + (logCount !== 1 ? 's' : '');

        const entry = document.createElement('div');
        entry.className = 'log-entry new ' + (type || 'default');

        const ts = document.createElement('span');
        ts.className = 'log-ts';
        ts.textContent = now();

        const msg = document.createElement('span');
        msg.className = 'log-msg';
        msg.textContent = message;

        entry.appendChild(ts);
        entry.appendChild(msg);
        logsEl.appendChild(entry);
        logsEl.scrollTop = logsEl.scrollHeight;

        if (agent && agent !== activeAgent) {
        if (activeAgent) setAgentState(activeAgent, 'done');
        activeAgent = agent;
        setAgentState(agent, 'running');
        }
        }

        function clearLogs() {
        logsEl.innerHTML = '<div class="log-empty" id="logEmpty">Waiting for workflow to start…</div>';
        logCount = 0;
        logCountEl.textContent = '0 events';
        activeAgent = null;
        Object.keys(agentIds).forEach(k => setAgentState(k, 'idle'));
        }

        function switchTab(name, btn) {
        document.querySelectorAll('.out-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.out-section').forEach(s => s.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('sec-' + name).classList.add('active');
        }

        function copyAll() {
        const content = document.getElementById('sec-all').innerText;
        navigator.clipboard.writeText(content).catch(() => {});
        }

        document.getElementById('workflowForm').addEventListener('submit', function () {
        runBtn.disabled = true;
        runBtn.textContent = 'Running…';
        statusDot.classList.add('running');
        addLog('Workflow started', 'info');
        });

        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/agentHub")
        .build();

        connection.on("ReceiveLog", function (message) {
        const { type, agent } = classifyLog(message);
        addLog(message, type, agent);
        });

        connection.on("WorkflowComplete", function () {
        if (activeAgent) setAgentState(activeAgent, 'done');
        activeAgent = null;
        statusDot.classList.remove('running');
        runBtn.disabled = false;
        runBtn.innerHTML = `<svg viewBox="0 0 16 16" fill="none"><polygon points="5,2 14,8 5,14" fill="currentColor"/></svg> Run workflow`;
        addLog('Workflow complete', 'info');
        });

        connection.start()
        .then(() => addLog('SignalR connected', 'info'))
        .catch(err => addLog('Connection failed: ' + err, 'err'));
    </script>

</body>
</html>
